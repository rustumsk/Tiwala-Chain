# AI service runtime configuration
APP_ENV=local

# Server
AI_HOST=0.0.0.0
AI_PORT=8000
AI_RELOAD=1

# CORS
AI_CORS_ALLOWED_ORIGINS=*

# Model
# Use ./fine_tuned_model for local offline testing, or a Hugging Face repo id for deployment.
MODEL_PATH=rustumsk/tiwala-bert
# MODEL_REVISION=main
# HF_TOKEN=replace-with-token-if-model-is-private

# Limits
AI_MAX_FILE_BYTES=3145728
AI_MAX_EXTRACTED_CHARS=60000
AI_MAX_CLAUSES=40

# Optional LLM suggestions
LLM_SUGGESTIONS_ENABLED=0
# LLM_SUGGESTIONS_PROVIDER=openai_compatible
# LLM_SUGGESTIONS_BASE_URL=https://api.groq.com/openai/v1
# LLM_SUGGESTIONS_MODEL=llama-3.3-70b-versatile
# LLM_SUGGESTIONS_TIMEOUT_SECONDS=45
# LLM_SUGGESTIONS_AUTH_MODE=bearer
# LLM_SUGGESTIONS_API_KEY=replace-with-api-key
# LLM_SUGGESTIONS_FORCE_ALL=false
# LLM_SUGGESTIONS_BATCH_SIZE=2
# LLM_SUGGESTIONS_MAX_CLAUSE_CHARS=1000
